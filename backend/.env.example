# Server
PORT=3000
NODE_ENV=development

# Database — omit to use in-memory MongoDB for development
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/creator-os

# Auth
JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_refresh_in_production

# CORS
CLIENT_URL=http://localhost:5173

# Logging
LOG_LEVEL=debug
