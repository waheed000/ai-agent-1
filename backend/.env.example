# =============================================================================
# CreatorOS AI — Environment Configuration
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# =============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Body parser size limit (e.g. 10mb, 5mb)
# BODY_LIMIT=10mb

# Number of proxy hops to trust for X-Forwarded-For (nginx: 1)
# TRUST_PROXY=1

# Graceful shutdown timeout in milliseconds
# SHUTDOWN_TIMEOUT_MS=15000

# ─── Database ─────────────────────────────────────────────────────────────────
# Omit MONGODB_URI to use an automatic in-memory MongoDB (development only)
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/creator-os

# DB_SERVER_SELECTION_TIMEOUT_MS=10000
# DB_SOCKET_TIMEOUT_MS=45000

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_refresh_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# BCRYPT_ROUNDS=10

# ─── Encryption ───────────────────────────────────────────────────────────────
# AES-256-GCM key for stored OAuth tokens — must be exactly 64 hex characters (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Logging ──────────────────────────────────────────────────────────────────
# error | warn | info | debug
LOG_LEVEL=debug

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis is optional — queues and caching degrade gracefully when unavailable
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
# RATE_LIMIT_MAX=100
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=10
# AI_RATE_LIMIT_WINDOW_MS=60000
# AI_RATE_LIMIT_MAX=20

# ─── Cache TTLs (seconds) ─────────────────────────────────────────────────────
# CACHE_TTL_ANALYTICS=3600
# CACHE_TTL_TRENDS=1800
# CACHE_TTL_COMPETITORS=1800
# CACHE_TTL_AI=86400
# CACHE_TTL_GENERAL=300

# ─── Queue Settings ───────────────────────────────────────────────────────────
# QUEUE_CONCURRENCY=2
# QUEUE_DEFAULT_ATTEMPTS=3
# QUEUE_RETRY_BASE_MS=1000
# QUEUE_RETRY_MAX_MS=30000
# QUEUE_RETAIN_COMPLETED=100
# QUEUE_RETAIN_COMPLETED_AGE=86400
# QUEUE_RETAIN_FAILED=200
# QUEUE_RETAIN_FAILED_AGE=604800

# ─── AI Providers ─────────────────────────────────────────────────────────────
# At least one provider should be configured to enable AI features.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# AI_DEFAULT_PROVIDER=gemini

# ─── OAuth Providers ──────────────────────────────────────────────────────────
# Configure only the platforms you intend to support.

# YouTube / Google
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REDIRECT_URI=http://localhost:3000/api/v1/auth/youtube/callback

# Instagram / Meta
# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=
# INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/v1/auth/instagram/callback

# LinkedIn
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_REDIRECT_URI=http://localhost:3000/api/v1/auth/linkedin/callback

# TikTok
# TIKTOK_CLIENT_ID=
# TIKTOK_CLIENT_SECRET=
# TIKTOK_REDIRECT_URI=http://localhost:3000/api/v1/auth/tiktok/callback

# X (Twitter)
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# X_REDIRECT_URI=http://localhost:3000/api/v1/auth/x/callback

# ─── Development Utilities ────────────────────────────────────────────────────
# Set to 'true' to suppress configuration warnings in CI/test environments
# SUPPRESS_CONFIG_WARNINGS=false
